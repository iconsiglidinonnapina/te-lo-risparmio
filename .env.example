# Amazon Creators API
# Credenziali ottenibili da: https://affiliate-program.amazon.com/creatorsapi
CREATORS_API_CREDENTIAL_ID=your-credential-id
CREATORS_API_CREDENTIAL_SECRET=your-credential-secret
CREATORS_API_CREDENTIAL_VERSION=1
CREATORS_API_PARTNER_TAG=mystore-21
CREATORS_API_MARKETPLACE=www.amazon.it

# App
PORT=3000
NODE_ENV=development

# CORS — origini consentite (separare con virgola)
# In produzione: URL GitHub Pages dell'organizzazione
CORS_ORIGINS=http://localhost:5173
# Produzione: https://iconsiglidinonnapina.github.io

# Frontend — URL base API (vuoto in dev grazie al proxy Vite)
# In produzione su GitHub Pages: URL del backend (es. https://te-lo-risparmio-api-xxxx.onrender.com)
# IMPORTANTE: aggiornare anche il CSP connect-src in index.html con lo stesso dominio
VITE_API_BASE_URL=
