{
  "name": "te-lo-risparmio",
  "version": "0.0.0",
  "description": "Te lo risparmio — analizza prezzi Amazon e suggerisce alternative migliori tramite Amazon Creators API",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vue-tsc --noEmit && vite build && node scripts/build-server.mjs",
    "build:client": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "vue-tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/static": "^8.1.0",
    "amazon-creators-api": "^1.2.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "lottie-web": "^5.13.0",
    "pinia": "^3.0.2",
    "posthog-js": "^1.364.6",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4",
    "vue3-lottie": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^22.15.3",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.1.2",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.1.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.4",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.2",
    "vitest": "^3.1.1",
    "vue-tsc": "^2.2.10"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,mjs}": [
      "prettier --write"
    ]
  }
}
